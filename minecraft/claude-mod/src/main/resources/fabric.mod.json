{
  "schemaVersion": 1,
  "id": "claudemod",
  "version": "${version}",
  "name": "Claude Bridge Command",
  "description": "Registers /claude <prompt>; the prompt is picked up by the claude-bridge sidecar via stdout. Server-only, no client install needed.",
  "authors": ["zachd"],
  "contact": {
    "homepage": "https://github.com/zdiemer/minecraft-k3s/tree/main/minecraft/claude-mod"
  },
  "license": "MIT",
  "environment": "server",
  "entrypoints": {
    "main": ["com.zachd.claudemod.ClaudeMod"]
  },
  "depends": {
    "fabricloader": ">=0.14",
    "fabric-api": ">=0.83",
    "minecraft": "~1.20.1",
    "java": ">=17",
    "fabric-permissions-api-v0": "*"
  }
}
