# syntax=docker/dockerfile:1

# old.diemer.codes -- the 2019 personal site, built as it was.
#
# Build context is web/old-diemer-codes/; the app source is the git submodule
# under site/ (zdiemer/diemer.codes @ develop). That repo is a frozen archive we
# deliberately do not touch, so this Dockerfile -- which by this repo's usual
# convention would sit next to the source -- lives here instead. That also means
# npm only ever runs in here, so the submodule worktree can never be dirtied by
# a build. See README.md.

# ---------------------------------------------------------------- build stage
# Node 16, and nothing newer. react-scripts 3.2 pulls webpack 4, which hashes
# module ids with crypto.createHash("md4"). Node 17+ links OpenSSL 3, which moved
# md4 out of the default provider, and the build dies with
#   error:0308010C:digital envelope routines::unsupported
# Node 16 is the last line bundling OpenSSL 1.1.1, where md4 is simply there.
#
# There is deliberately NO NODE_OPTIONS=--openssl-legacy-provider here. That flag
# is registered only when node is compiled against OpenSSL 3 (node_options.cc is
# #if'd on OPENSSL_VERSION_MAJOR >= 3), so on THIS image node refuses to start
# with "bad option". It is the fix for building this on Node 18/20; here it is a
# self-inflicted outage.
#
# bullseye, not alpine: a 2019 tree (1171 packages, 312 still on sha1 integrity)
# resolved against glibc. This stage is discarded, so its size costs nothing,
# while a musl surprise six years later would cost an evening.
FROM node:16-bullseye AS build

WORKDIR /src

# lessc is NOT a dependency of this project. package.json's `build-css` shells
# out to it, but `less` appears in neither package.json nor package-lock.json --
# it was a global on the machine this was written on in 2019. Reproduce that
# honestly, since adding it to the app repo is off the table.
#
# less 4, pinned, and specifically NOT less 3: less 3 performed `/` as division
# everywhere, which rewrites site.less:236's `(max-device-aspect-ratio: 10/16)`
# to `0.625` and silently breaks that media query. less 4 defaults to
# parens-division and emits the ratio untouched. If the site ever renders
# styled-but-wrong, less 3 is not the fallback -- it is the cause.
RUN npm install -g less@4.2.0

# Manifests first, so editing the site's source doesn't re-run the install.
COPY site/package.json site/package-lock.json ./

# `ci`, not `install`: the tree comes from the lock and can never drift forward.
# All ten package.json deps resolve inside their lock ranges, so the sync check
# passes.
#
# --legacy-peer-deps: package-lock.json is lockfileVersion 1, written by npm 5/6,
# which ignored peer dependencies entirely. npm 8 (what Node 16 ships) enforces
# them and can ERESOLVE on a tree npm 6 was perfectly happy with. This restores
# npm 6 semantics -- precisely what a 2019 lock wants -- and does not change which
# versions get installed, because `ci` takes those from the lock either way.
RUN npm ci --legacy-peer-deps --no-audit --no-fund

COPY site/ ./

# Drops the dead Google Analytics tag, actually loads Fira Code, and adds the
# archive banner. Lands after `COPY site/` so it wins. See overlay/index.html for
# the full reasoning.
COPY overlay/index.html ./public/index.html

# Site.jsx declares 22 styled-components and renders only some of them, so
# `react-scripts build` emits no-unused-vars warnings -- and CRA turns warnings
# into hard errors when process.env.CI is truthy. docker build does not inherit
# host env, so this is belt and braces; it is also the note explaining why nobody
# should ever "helpfully" plumb CI in via --build-arg.
ENV CI=false

# THE ORDER OF THE NEXT TWO LINES IS LOAD-BEARING.
#
# public/index.html links %PUBLIC_URL%/site.css. site.css is generated by lessc,
# is gitignored upstream (`public/site.css*`), and is not on disk anywhere. `npm
# run build` does NOT run build-css. CRA copies public/* into build/ verbatim, so
# site.css has to exist BEFORE the build runs.
#
# Get this wrong and nothing complains: react-scripts succeeds, nginx returns
# 200, and the site renders with zero styling. That is the worst failure mode in
# this deployment -- no exit code, log line, probe or status code reports it --
# which is why the assertions below exist.
RUN npm run build-css
RUN npm run build

# Fail HERE, loudly, rather than in production, silently.
#   site.css non-empty         -> lessc ran at all
#   grep about-me-body         -> lessc actually COMPILED site.less (site.less:36),
#                                 rather than emitting an empty file
#   grep site.css in the html  -> index.html still points at it after CRA's
#                                 html-minifier pass
#   grep -v gtag               -> the overlay landed and GA is really gone
#   grep archive-banner        -> both halves of the banner survived that same
#                                 pass. CRA minifies index.html with
#                                 removeComments + minifyCSS, so the markup and
#                                 its <style> are the two things it could eat,
#                                 and a page that quietly stops saying it is an
#                                 archive is the failure this guards.
RUN set -eux; \
    test -s build/index.html; \
    test -s build/site.css; \
    test -s build/service-worker.js; \
    test -d build/static; \
    grep -q 'about-me-body' build/site.css; \
    grep -q 'site\.css' build/index.html; \
    grep -q 'Fira+Code' build/index.html; \
    grep -q 'archived copy' build/index.html; \
    grep -q '\.archive-banner' build/index.html; \
    ! grep -q 'gtag' build/index.html

# -------------------------------------------------------------- runtime stage
# Same base as web/kelsey-green: uid 101, binds 8080, no root anywhere, and
# already proven on this cluster under readOnlyRootFilesystem.
FROM nginxinc/nginx-unprivileged:1.29-alpine

# Replaces the stock default.conf. The base image's /docker-entrypoint.d scripts
# test writability before touching this file, so a read-only rootfs is fine.
COPY nginx.conf /etc/nginx/conf.d/default.conf

# Left root-owned on purpose: nginx runs as 101 and only ever reads, so it has no
# business being able to write its own docroot.
COPY --from=build /src/build/ /usr/share/nginx/html/

# The base image already sets USER 101 and CMD ["nginx", "-g", "daemon off;"].
EXPOSE 8080
