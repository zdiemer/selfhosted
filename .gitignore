# Local Helm state
charts/
Chart.lock
*.tgz

# Editor / OS cruft
.DS_Store
.vscode/
.idea/
*.swp
*~

# Secrets — never commit. Use kubectl create secret or sealed-secrets instead.
*-secret.yaml
*.secret.yaml
secrets/

# Local-only overlays (per-project secrets: tokens, passwords, identities).
# The ** glob covers every subproject's values.local.yaml.
**/values.local.yaml
.claude/settings.local.json

# Gradle build artifacts (claude-mod). The JAR is sideloaded via install.sh,
# not checked in.
**/build/
**/.gradle/

# Claude-mod compileOnly jar cache, populated from the live mc pod by
# install.sh's prep_libs() — never committed.
minecraft/claude-mod/libs/
